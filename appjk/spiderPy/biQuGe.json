{
    "id": "beiquge",
    "name": "笔趣阁",
    "description": "笔趣阁小说阅读网，支持分类、首页、详情、章节和搜索解析。",
    "baseUrl": "https://www.beiquge.com",
    "category": {
        "url": "https://www.beiquge.com/sort/",
        "requestMethod": "okhttp",
        "responseType": "html",
        "parseType": "xpath",
        "listExpr": "//div[contains(@class,'nav')]//a[contains(@href,'/sort/') and contains(@href,'_1.html')]",
        "itemExpr": "",
        "nameExpr": "normalize-space(.)",
        "valueExpr": "@href",
        "jsExpr": ""
    },
    "home": {
        "url": "https://www.beiquge.com/",
        "requestMethod": "okhttp",
        "responseType": "html",
        "parseType": "xpath",
        "listExpr": "//div[contains(@class,'novelslist')]//li[.//a[contains(@href,'/book/')]]",
        "itemExpr": "",
        "nameExpr": "normalize-space(.//a[contains(@href,'/book/')][1])",
        "urlExpr": ".//a[contains(@href,'/book/')][1]/@href",
        "imgExpr": "",
        "authorExpr": "",
        "tagExpr": "",
        "descExpr": "normalize-space(.//a[contains(@href,'/book/')][2])",
        "contentExpr": "",
        "statusExpr": "",
        "scoreExpr": "",
        "updateTimeExpr": "",
        "yearExpr": "",
        "jsExpr": ""
    },
    "categoryList": {
        "url": "https://www.beiquge.com/sort/{categoryId}_{page}.html",
        "requestMethod": "okhttp",
        "responseType": "html",
        "parseType": "xpath",
        "listExpr": "//div[contains(@class,'novelslist')]//li[.//a[contains(@href,'/book/')]]",
        "itemExpr": "",
        "nameExpr": "normalize-space(.//a[contains(@href,'/book/')][1])",
        "urlExpr": ".//a[contains(@href,'/book/')][1]/@href",
        "imgExpr": "",
        "authorExpr": "",
        "tagExpr": "",
        "descExpr": "normalize-space(.//a[contains(@href,'/book/')][2])",
        "contentExpr": "",
        "statusExpr": "",
        "scoreExpr": "",
        "updateTimeExpr": "",
        "yearExpr": "",
        "jsExpr": ""
    },
    "detail": {
        "url": "https://www.beiquge.com{ id }",
        "requestMethod": "okhttp",
        "responseType": "html",
        "parseType": "xpath",
        "nameExpr": "normalize-space(//div[@id='maininfo']//div[@id='info']/h1/text())",
        "urlExpr": "",
        "imgExpr": "normalize-space(//div[@id='fmimg']//img/@src)",
        "authorExpr": "normalize-space(//div[@id='info']/p[1])",
        "tagExpr": "normalize-space(//div[@id='info']/p[2])",
        "descExpr": "normalize-space(//div[@id='intro']/p[1])",
        "contentExpr": "//div[@id='list']//dd/a/@href",
        "statusExpr": "normalize-space(//div[@id='info']/p[3])",
        "scoreExpr": "",
        "updateTimeExpr": "normalize-space(//div[@id='info']/p[4])",
        "yearExpr": "",
        "jsExpr": ""
    },
    "content": {
        "enabled": true,
        "url": "https://www.beiquge.com{ id }",
        "requestMethod": "okhttp",
        "responseType": "html",
        "parseType": "xpath",
        "contentExpr": "normalize-space(//div[@id='content'])",
        "jsExpr": ""
    },
    "searchList": {
        "url": "https://www.beiquge.com/search.php?keyword={keyword}",
        "requestMethod": "okhttp",
        "responseType": "html",
        "parseType": "xpath",
        "listExpr": "//div[contains(@class,'novelslist')]//li[.//a[contains(@href,'/book/')]]",
        "itemExpr": "",
        "nameExpr": "normalize-space(.//a[contains(@href,'/book/')][1])",
        "urlExpr": ".//a[contains(@href,'/book/')][1]/@href",
        "imgExpr": "",
        "authorExpr": "",
        "tagExpr": "",
        "descExpr": "normalize-space(.//a[contains(@href,'/book/')][2])",
        "contentExpr": "",
        "statusExpr": "",
        "scoreExpr": "",
        "updateTimeExpr": "",
        "yearExpr": "",
        "jsExpr": ""
    }
}